# --- Build stage: compile shared + channel-plugin ---
FROM node:20-slim AS build

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/
COPY packages/channel-plugin/package.json packages/channel-plugin/
RUN pnpm install --frozen-lockfile

COPY packages/shared/ packages/shared/
COPY packages/channel-plugin/ packages/channel-plugin/
RUN pnpm --filter @chat-mcp/shared build && pnpm --filter @chat-mcp/channel-plugin build

# --- Runtime stage ---
FROM node:20-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    openssh-client git curl \
    && rm -rf /var/lib/apt/lists/*

RUN npm i -g @anthropic-ai/claude-code

# Copy the full built workspace — pnpm's symlink structure stays intact
COPY --from=build /app /opt/chat-mcp

# Entrypoint
COPY docker/agent-entrypoint.sh /usr/local/bin/agent-entrypoint.sh
RUN chmod +x /usr/local/bin/agent-entrypoint.sh

WORKDIR /workspace

ENTRYPOINT ["agent-entrypoint.sh"]
