#!/usr/bin/env bash
# Launch a Claude Code agent in Docker, connected to the chat room.
#
# Agents ALWAYS run in Docker — --dangerously-skip-permissions is only
# safe inside a container sandbox.
#
# Usage: chat-agent <profile> <letter> [project-dir] [-- claude args...]
#   chat-agent alice A                        # cwd, instance A
#   chat-agent alice B ~/code/my-project      # specific project, instance B
#   chat-agent alice A . -- -c                # resume session

set -euo pipefail

SOURCE="$0"
while [ -L "$SOURCE" ]; do SOURCE="$(readlink "$SOURCE")"; done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

PROFILE="${1:?Usage: chat-agent <profile> <letter> [project-dir] [-- claude args...]}"
LETTER="${2:?Usage: chat-agent <profile> <letter> [project-dir] [-- claude args...]}"
shift 2

PROJECT_DIR="$(pwd)"
if [ $# -gt 0 ] && [ "$1" != "--" ]; then
  PROJECT_DIR="$1"
  shift
fi
PROJECT_DIR=$(cd "$PROJECT_DIR" && pwd)
[ "${1:-}" = "--" ] && shift

# --- Validate prerequisites ---
if [ -z "${ANTHROPIC_API_KEY:-}" ]; then
  echo "ERROR: ANTHROPIC_API_KEY must be set." >&2
  echo "  export ANTHROPIC_API_KEY=sk-ant-..." >&2
  exit 1
fi

if ! command -v docker &> /dev/null; then
  echo "ERROR: docker is required but not installed." >&2
  exit 1
fi

# --- Register agent identity (runs on host — just API calls) ---
eval $("$SCRIPT_DIR/chat-agent-register" "$PROFILE" "$PROJECT_DIR" "$LETTER")

# --- Build Docker image ---
echo "Building agent image..." >&2
docker build -q -t chat-mcp-agent -f "$REPO_DIR/Dockerfile.agent" "$REPO_DIR" >&2

# --- Launch container ---
exec docker run -it --rm \
  --name "chat-agent-${CHAT_DISPLAY_NAME}" \
  -e "CHAT_SERVER_URL=$CHAT_SERVER_URL" \
  -e "CHAT_PARTICIPANT_ID=$CHAT_PARTICIPANT_ID" \
  -e "CHAT_ROOMS=$CHAT_ROOMS" \
  -e "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}" \
  -v "${CHAT_SSH_KEY_PATH}:/keys/key:ro" \
  -v "${CHAT_SSH_KEY_PATH}.pub:/keys/key.pub:ro" \
  -v "${PROJECT_DIR}:/workspace" \
  --add-host=host.docker.internal:host-gateway \
  chat-mcp-agent "$@"
